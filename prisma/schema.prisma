generator client { provider = "prisma-client-js" }
datasource db { provider = "sqlite" url = env("DATABASE_URL") }
model Role { id Int @id @default(autoincrement()) code String @unique name String users User[] }
model User { id Int @id @default(autoincrement()) username String @unique passwordHash String name String roleId Int role Role @relation(fields:[roleId],references:[id]) tasks Task[] customers Customer[] }
model ShiftSchedule { id Int @id @default(autoincrement()) date DateTime userId Int shift String startTime String endTime String user User @relation(fields:[userId],references:[id]) }
model Customer { id Int @id @default(autoincrement()) code String @unique name String platform String level String ownerId Int owner User @relation(fields:[ownerId],references:[id]) followUps FollowUpRecord[] calls CallRecord[] reminders RepurchaseReminder[] tasks Task[] }
model Task { id Int @id @default(autoincrement()) date DateTime userId Int user User @relation(fields:[userId],references:[id]) type String name String status String dueAt DateTime customerId Int? customer Customer? @relation(fields:[customerId],references:[id]) followUpId Int? callRecordId Int? }
model FollowUpRecord { id Int @id @default(autoincrement()) date DateTime userId Int customerId Int customer Customer @relation(fields:[customerId],references:[id]) }
model CallRecord { id Int @id @default(autoincrement()) date DateTime userId Int customerId Int connected Boolean durationSec Int validCall Boolean customer Customer @relation(fields:[customerId],references:[id]) }
model InquiryConversion { id Int @id @default(autoincrement()) date DateTime userId Int platform String validInquiry Int dealCustomers Int amount Float }
model KpiRecord { id Int @id @default(autoincrement()) date DateTime userId Int score Float reached Boolean }
model RepurchaseReminder { id Int @id @default(autoincrement()) remindDate DateTime customerId Int status String customer Customer @relation(fields:[customerId],references:[id]) }
model ReviewRecord { id Int @id @default(autoincrement()) date DateTime userId Int customerName String status String }
model SocialPostRecord { id Int @id @default(autoincrement()) date DateTime userId Int type String posted Boolean screenshot String? note String? }
model CompetitorIntel { id Int @id @default(autoincrement()) date DateTime userId Int brand String platform String }
model ProblemReview { id Int @id @default(autoincrement()) date DateTime userId Int type String detail String }
model ScriptMaterial { id Int @id @default(autoincrement()) title String category String content String enabled Boolean @default(true) }
model TaskRule { id Int @id @default(autoincrement()) shift String taskType String startTime String endTime String }
model SystemSetting { id Int @id @default(autoincrement()) key String @unique value String }
model Lead { id Int @id @default(autoincrement()) createdAt DateTime @default(now()) date String staff String shop String inquiryType String model String customerType String buyerId String phone String? wechat String? wechatAdded Boolean holdSent Boolean intentLevel Int? tier String? note String? }
model FollowupLog { id Int @id @default(autoincrement()) createdAt DateTime @default(now()) date String staff String shop String buyerId String status String statusNote String? isDeal Boolean dealAmount Float? lostReason String? nextAction String? }
model DailyActivity { id Int @id @default(autoincrement()) date String staff String lastSubmitAt DateTime @default(now()) leadsAdded Int @default(0) followupsAdded Int @default(0) dealsAdded Int @default(0) dealAmountAdded Float @default(0) @@unique([date, staff]) }

model DailySales { id Int @id @default(autoincrement()) date String staff String shop String reception Int aftersale Int invalidInquiry Int presale Int deals Int sales Float createdAt DateTime @default(now()) }
